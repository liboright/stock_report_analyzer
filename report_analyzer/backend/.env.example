# 路径配置（Windows 路径用正斜杠或反斜杠都可；统一为小写 D:/quant/...）
REPORT_DATA_PATH=D:/quant/report_data
DEEP_RESEARCH_PATH=D:/quant/deep-research-report
SCRIPT_PATH=D:/quant/report_analyzer/scripts
MAPPING_PATH=D:/quant/report_data/mapping.json
DB_PATH=D:/quant/report_data/.claude_state/state.db
LOG_DIR=D:/quant/report_data/.claude_state/logs

# 注：MinerU 解析器已内嵌到 app/services/mineru_parser/，不再需要外部 REPORT_GEN_PATH 路径

# LLM（Anthropic Claude）
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# PDF 解析（MinerU 在线 API）
MINERU_API_KEY=eyJ...
MINERU_API_BASE=https://mineru.net/api/v4

# 服务
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
